<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body>
  <form action="/post-user" method="post">

    <div style="width:600;margin:auto">
      <h1 style="padding: 10px 0">
        Create a user:
      </h1>
      <div class="mb-3">
        <label class="form-label">Name:</label>
        <input type="text" class="form-control" name="myName" placeholder="John Cena">
      </div>
      <div class="mb-3">
        <label class="form-label">Email:</label>
        <input class="form-control" type="email" name="myEmail" rows="3"></input>
      </div>
      <div class="mb-3">
        <label class="form-label">Address:</label>
        <textarea class="form-control" name="myAddress" rows="3"></textarea>
      </div>
      <div class="mb-3">
        <button class="btn btn-warning" type="submit" id="btn">Submit</button>
      </div>
    </div>
  </form>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous"></script>
</body>

</html>