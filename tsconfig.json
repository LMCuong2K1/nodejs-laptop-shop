{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "app/*": [
        "./src/app/*"
      ],
      "config/*": [
        "./src/config/*"
      ],
      "controllers/*": [
        "./src/controllers/*"
      ],
      "services/*": [
        "./src/services/*"
      ],
      "models/*": [
        "./src/models/*"
      ],
      "routes/*": [
        "./src/routes/*"
      ],
      "environment/*": [
        "./environments/*"
      ],
      "shared/*": [
        "./src/app/_shared/*"
      ],
      "helpers/*": [
        "./src/helpers/*"
      ],
      "tests/*": [
        "./src/tests/*"
      ]
    }
  }
}